{
  "name": "@getrheo/react-native-expo",
  "version": "2.0.2",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests --config ../react-native-core/vitest.config.ts",
    "build": "node ../../../scripts/build-publishable-package.mjs",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@getrheo/react-native-core": "2.0.2"
  },
  "peerDependencies": {
    "@react-native-async-storage/async-storage": ">=2",
    "expo-store-review": "*",
    "expo-video": "*",
    "lottie-react-native": "*",
    "react": ">=18",
    "react-native": ">=0.79",
    "react-native-gesture-handler": "*",
    "react-native-linear-gradient": "*",
    "react-native-permissions": ">=5",
    "react-native-reanimated": "*",
    "react-native-safe-area-context": "*",
    "react-native-svg": "*",
    "react-native-vector-icons": ">=10"
  },
  "devDependencies": {
    "@rheo/config": "workspace:*",
    "@getrheo/contracts": "2.0.2",
    "@getrheo/flow-runtime": "2.0.2",
    "@getrheo/react-native-core": "2.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@types/react": "^19.0.1",
    "expo-store-review": "~9.0.0",
    "expo-video": "~3.0.0",
    "lottie-react-native": "^7.2.2",
    "react": "^19.0.0",
    "react-native": "0.83.6",
    "react-native-gesture-handler": "~2.30.1",
    "react-native-linear-gradient": "^2.8.3",
    "react-native-permissions": "^5.5.1",
    "react-native-reanimated": "~4.2.1",
    "react-native-safe-area-context": "~5.6.1",
    "react-native-svg": "15.15.4",
    "react-native-vector-icons": "^10.2.0",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "publishConfig": {
    "access": "public",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js",
        "default": "./dist/index.js"
      }
    },
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts"
  },
  "homepage": "https://docs.getrheo.io/docs/developer-guide/sdk",
  "description": "Rheo React Native SDK for Expo and Expo dev client.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getrheo/rheo-react-native.git",
    "directory": "packages/sdks/react-native-expo"
  },
  "bugs": {
    "url": "https://github.com/getrheo/rheo-react-native/issues"
  }
}
