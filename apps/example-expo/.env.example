# @rheo/example-expo — copy to apps/example-expo/.env
# EXPO_PUBLIC_* are embedded at build time (see app/index.tsx, lib/*Bootstrap.ts).

# Default API base URL for the config screen (publishable key + channel id are entered in-app).
#   - iOS simulator: http://localhost:4000
#   - Android emulator: http://10.0.2.2:4000
#   - Physical device: http://<your-lan-ip>:4000
EXPO_PUBLIC_API_BASE_URL=http://localhost:4000

# Optional — RevenueCat public SDK keys (lib/revenueCatBootstrap.ts).
# Requires custom dev client (`expo run:ios` / `expo run:android`); not Expo Go.
# EXPO_PUBLIC_REVENUECAT_IOS_API_KEY=appl_...
# EXPO_PUBLIC_REVENUECAT_ANDROID_API_KEY=goog_...

# Optional — AppsFlyer MMP (lib/appsFlyerBootstrap.ts). Dev build only, not Expo Go.
# EXPO_PUBLIC_APPSFLYER_DEV_KEY=
# EXPO_PUBLIC_APPSFLYER_IOS_APP_ID=
